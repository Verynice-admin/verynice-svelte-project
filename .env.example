# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=verynice
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase Admin API access
FIREBASE_ADMIN_TOKEN=your_firebase_admin_token

# Map configuration (now using Leaflet with OpenStreetMap - no API key needed)
# Previously: PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Previously: VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Pexels API (for stock photos)
PEXELS_API_KEY=your_pexels_api_key

# AI Translation API Keys (3-layer fallback system)
# Primary: Groq - Llama 3.3 Versatile (high TPM free tier)
GROQ_API_KEY=your_groq_api_key

# Fallback 1: Gemini 2.5 Flash Lite (1000 req/day free)
GEMINI_API_KEY=your_gemini_api_key

# Fallback 2: OpenRouter (auto-selects best available free model)
OPENROUTER_API_KEY=your_openrouter_api_key
