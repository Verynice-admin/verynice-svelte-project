{
  "agents": [
    {
      "name": "DeepSeek",
      "provider": "deepseek",
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "enabled": true,
      "config": {
        "model": "deepseek-chat",
        "temperature": 0.7,
        "maxTokens": 4096,
        "baseURL": "https://api.deepseek.com/v1"
      }
    },
    {
      "name": "Qwen",
      "provider": "qwen",
      "apiKeyEnv": "QWEN_API_KEY",
      "enabled": true,
      "config": {
        "model": "qwen-turbo",
        "temperature": 0.7,
        "maxTokens": 4096,
        "baseURL": "https://dashscope.aliyuncs.com/api/v1"
      }
    }
  ],
  "settings": {
    "defaultAgent": "DeepSeek",
    "fallbackAgent": "Qwen",
    "retryAttempts": 2,
    "timeout": 30000
  }
}
