rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // 1. PAGES - Public read (for website content)
    // ========================================
    match /pages/{pageId} {
      allow read: if true;
      
      // Counter updates for view/like counts
      allow update: if isCounterOnlyUpdate();

      function isCounterOnlyUpdate() {
        let diff = request.resource.data.diff(resource.data);
        return diff.changedKeys().hasOnly(['articleViews', 'articleLikes', 'articleComments']) &&
               diff.addedKeys().size() == 0 &&
               diff.removedKeys().size() == 0 &&
               validInc('articleViews') &&
               validInc('articleLikes') &&
               validInc('articleComments');
      }

      function validInc(field) {
        return (request.resource.data[field] is int) &&
               (resource.data[field] is int) &&
               (
                 request.resource.data[field] == resource.data[field] ||
                 request.resource.data[field] == resource.data[field] + 1
               );
      }
    }

    // ========================================
    // 2. COMMENTS - Public read, authenticated create
    // ========================================
    match /pages/{pageId}/comments/{commentId} {
      allow read: if true;
      // request.auth != null blocks direct client writes from unauthenticated attackers.
      // Legitimate comments go through /api/comments/submit (Admin SDK) which bypasses rules.
      allow create: if request.auth != null && isValidComment();

      function isValidComment() {
        return request.resource.data.size() <= 3 &&
               request.resource.data.text is string &&
               request.resource.data.text.size() > 0 &&
               request.resource.data.text.size() <= 1000 &&
               (
                 !('author' in request.resource.data) ||
                 (request.resource.data.author is string && request.resource.data.author.size() <= 80)
               ) &&
               request.resource.data.createdAt == request.time;
      }
    }

    // ========================================
    // 3. USERS - Authenticated users read/write own doc ONLY
    // ========================================
    match /users/{userId} {
      // Authenticated users can read/write ONLY their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // 4. USERS/PRIVATE - Sensitive PII subcollection (phone, address, etc.)
    //    Independently secured so it can be locked down separately from
    //    the public user profile in users/{userId}.
    // ========================================
    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // 5. DEFAULT - Deny everything else
    // ========================================
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
