rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    // Only the verified project owner may write editorial content.
    // Google OAuth always provides email_verified=true, which guards against
    // unverified email/password accounts using the same address.
    function isOwner() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email == 'headquarters.mailbox@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBusinessOwner() {
      return isSignedIn()
          && resource.data.businessId == request.auth.uid;
    }

    function isCreatingOwnBusinessResource() {
      return isSignedIn()
          && request.resource.data.businessId == request.auth.uid;
    }

    function keepsBusinessOwner() {
      return request.resource.data.businessId == resource.data.businessId;
    }

    function isUserDocumentCreate(userId) {
      return isSelf(userId)
          && request.resource.data.uid == userId
          && request.resource.data.role in ['traveller', 'business'];
    }

    function isUserDocumentUpdate(userId) {
      let diff = request.resource.data.diff(resource.data);
      return isSelf(userId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role
          && !diff.changedKeys().hasAny(['email', 'createdAt'])
          && !diff.addedKeys().hasAny(['admin', 'isAdmin', 'suspended']);
    }

    // ========================================
    // 1. PAGES - Public read (for website content)
    // ========================================
    match /pages/{pageId} {
      allow read: if true;

      // Counter updates for view/like counts - requires auth token to prevent REST API abuse
      allow update: if isSignedIn() && isCounterOnlyUpdate();

      function isCounterOnlyUpdate() {
        let diff = request.resource.data.diff(resource.data);
        return diff.changedKeys().hasOnly(['articleViews', 'articleLikes', 'articleComments']) &&
               diff.addedKeys().size() == 0 &&
               diff.removedKeys().size() == 0 &&
               validInc('articleViews') &&
               validInc('articleLikes') &&
               validInc('articleComments');
      }

      function validInc(field) {
        return (request.resource.data[field] is int) &&
               (resource.data[field] is int) &&
               (
                 request.resource.data[field] == resource.data[field] ||
                 request.resource.data[field] == resource.data[field] + 1
               );
      }
    }

    // ========================================
    // 2. PAGES SUBCOLLECTIONS - Public read, owner write
    //    Covers the deeply nested structure used by the admin panel:
    //      pages/destinationsPage/articles/{region}/attractions/{slug}/articles/{id}
    //      pages/travelTipsPage/tips/{id}
    //    The content is already public (it IS the website). Writes are
    //    restricted to the verified owner account via isOwner().
    // ========================================
    match /pages/{pageId}/{rest=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    // ========================================
    // 3. COMMENTS - Public read, authenticated create
    // ========================================
    match /pages/{pageId}/comments/{commentId} {
      allow read: if true;
      // request.auth != null blocks direct client writes from unauthenticated attackers.
      // Legitimate comments go through /api/comments/submit (Admin SDK) which bypasses rules.
      allow create: if request.auth != null && isValidComment();

      function isValidComment() {
        return request.resource.data.size() <= 3 &&
               request.resource.data.text is string &&
               request.resource.data.text.size() > 0 &&
               request.resource.data.text.size() <= 1000 &&
               (
                 !('author' in request.resource.data) ||
                 (request.resource.data.author is string && request.resource.data.author.size() <= 80)
               ) &&
               request.resource.data.createdAt == request.time;
      }
    }

    // ========================================
    // 4. USERS - Authenticated users read/write own doc ONLY
    // ========================================
    match /users/{userId} {
      allow read: if isSelf(userId) || isOwner();
      allow create: if isUserDocumentCreate(userId) || isOwner();
      allow update: if isUserDocumentUpdate(userId) || isOwner();
      allow delete: if isSelf(userId) || isOwner();
    }

    // ========================================
    // 5. USER SUBCOLLECTIONS - Owner-only traveller/dashboard data
    // ========================================
    match /users/{userId}/{collectionId}/{docId} {
      allow read, write: if isSelf(userId) || isOwner();
    }

    // ========================================
    // 6. BUSINESSES - Business profile belongs to the authenticated user
    // ========================================
    match /businesses/{businessId} {
      allow read, write: if isSelf(businessId) || isOwner();
    }

    // ========================================
    // 7. LISTINGS - Public can read published listings; businesses manage their own
    // ========================================
    match /listings/{listingId} {
      allow read: if resource.data.status == 'published' || isBusinessOwner() || isOwner();
      allow create: if isCreatingOwnBusinessResource() || isOwner();
      allow update: if (isBusinessOwner() && keepsBusinessOwner()) || isOwner();
      allow delete: if isBusinessOwner() || isOwner();
    }

    // ========================================
    // 8. BOOKINGS, REVIEWS, MESSAGES - Business scoped dashboard records
    // ========================================
    match /bookings/{bookingId} {
      allow read, update: if isBusinessOwner() || isOwner();
      allow create: if isCreatingOwnBusinessResource() || isOwner();
      allow delete: if isOwner();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isCreatingOwnBusinessResource() || isOwner();
      allow update: if (isBusinessOwner() && keepsBusinessOwner()) || isOwner();
      allow delete: if isOwner();
    }

    match /messages/{messageId} {
      allow read: if isBusinessOwner() || isOwner();
      allow create: if isCreatingOwnBusinessResource() || isOwner();
      allow update: if (isBusinessOwner() && keepsBusinessOwner()) || isOwner();
      allow delete: if isOwner();
    }

    // ========================================
    // 9. CLIENT CONFIG - Public read, server/admin writes only
    // ========================================
    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /siteConfig/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // ========================================
    // 10. DEFAULT - Deny everything else
    // ========================================
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }

  }
}
