rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    // Only the verified project owner may write editorial content.
    // Google OAuth always provides email_verified=true, which guards against
    // unverified email/password accounts using the same address.
    function isOwner() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email == 'contact.azamat@gmail.com';
    }

    // ========================================
    // 1. PAGES - Public read (for website content)
    // ========================================
    match /pages/{pageId} {
      allow read: if true;

      // Counter updates for view/like counts
      allow update: if isCounterOnlyUpdate();

      function isCounterOnlyUpdate() {
        let diff = request.resource.data.diff(resource.data);
        return diff.changedKeys().hasOnly(['articleViews', 'articleLikes', 'articleComments']) &&
               diff.addedKeys().size() == 0 &&
               diff.removedKeys().size() == 0 &&
               validInc('articleViews') &&
               validInc('articleLikes') &&
               validInc('articleComments');
      }

      function validInc(field) {
        return (request.resource.data[field] is int) &&
               (resource.data[field] is int) &&
               (
                 request.resource.data[field] == resource.data[field] ||
                 request.resource.data[field] == resource.data[field] + 1
               );
      }
    }

    // ========================================
    // 2. PAGES SUBCOLLECTIONS - Public read, owner write
    //    Covers the deeply nested structure used by the admin panel:
    //      pages/destinationsPage/articles/{region}/attractions/{slug}/articles/{id}
    //      pages/travelTipsPage/tips/{id}
    //    The content is already public (it IS the website). Writes are
    //    restricted to the verified owner account via isOwner().
    // ========================================
    match /pages/{pageId}/{rest=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    // ========================================
    // 3. COMMENTS - Public read, authenticated create
    // ========================================
    match /pages/{pageId}/comments/{commentId} {
      allow read: if true;
      // request.auth != null blocks direct client writes from unauthenticated attackers.
      // Legitimate comments go through /api/comments/submit (Admin SDK) which bypasses rules.
      allow create: if request.auth != null && isValidComment();

      function isValidComment() {
        return request.resource.data.size() <= 3 &&
               request.resource.data.text is string &&
               request.resource.data.text.size() > 0 &&
               request.resource.data.text.size() <= 1000 &&
               (
                 !('author' in request.resource.data) ||
                 (request.resource.data.author is string && request.resource.data.author.size() <= 80)
               ) &&
               request.resource.data.createdAt == request.time;
      }
    }

    // ========================================
    // 4. USERS - Authenticated users read/write own doc ONLY
    // ========================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // 5. USERS/PRIVATE - Sensitive PII subcollection
    // ========================================
    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // 6. DEFAULT - Deny everything else
    // ========================================
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }

  }
}
