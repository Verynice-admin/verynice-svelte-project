    '\t\t\t<div class="timeout-modal-actions">\n' +
    '\t\t\t\t<button class="btn-primary" on:click={() => { showTimeoutWarning = false; }}>\n' +
    '\t\t\t\t\tStay Logged In\n' +
    '\t\t\t\t</button>\n' +
    `\t\t\t\t<button class="btn-secondary" on:click={() => goto('/')}>\n` +
    '\t\t\t\t\tSign Out\n' +
    '\t\t\t\t</button>\n' +
    '\t\t\t</div>\n' +
    '\t\t</div>\n' +
