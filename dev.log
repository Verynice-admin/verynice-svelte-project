    '\t\t\ton:focus={() => isSearchOpen = true}\n' +
    '\t\t\ton:keydown={(e) => {\n' +
    "\t\t\t\tif (e.key === 'Enter' && e.currentTarget.value.trim()) {\n" +
    '\t\t\t\t\tisSearchOpen = true;\n' +
    '\t\t\t\t}\n' +
    '\t\t\t}}\n' +
    '\t\t/>\n' +
    '\t\t{#if searchQuery}\n' +
