    "\t\t\t\timport('$components/features/ui-elements/BackToTop.svelte'),\n" +
    "\t\t\t\timport('$lib/components/ui/TranslationProgressBar.svelte')\n" +
    '\t\t\t]).then(([backToTop, translation]) => {\n' +
    "\t\t\t\tconsole.log('[Layout] Components loaded:', { backToTop: !!backToTop, translation: !!translation });\n" +
    '\t\t\t\tBackToTop = backToTop.default;\n' +
    '\t\t\t\tTranslationProgressBar = translation.default;\n' +
    '\t\t\t\tcomponentsLoaded = true;\n' +
    "\t\t\t}).catch(err => console.error('Failed to load components:', err));\n" +
    '\t\t};\n' +
    '\n' +
    "\t\tif ('requestIdleCallback' in window) {\n" +
    '\t\t\trequestIdleCallback(loadComponents, { timeout: 1000 });\n' +
    '\t\t} else {\n' +
    '\t\t\tsetTimeout(loadComponents, 100);\n' +
    '\t\t}\n' +
    '\t\t\n' +
    '\t\t// Cleanup function - returned at the END of onMount\n' +
    '\t\treturn () => {\n' +
    '\t\t\tif (authUnsubscribe) authUnsubscribe();\n' +
    '\t\t\tactivityEvents.forEach(event => {\n' +
    '\t\t\t\twindow.removeEventListener(event, handleUserActivity);\n' +
    '\t\t\t});\n' +
    '\t\t\tclearTimeout(idleTimer);\n' +
    '\t\t\tclearTimeout(sessionTimer);\n' +
    '\t\t\tclearInterval(countdownInterval);\n' +
    '\t\t};\n' +
    '\t});\n' +
    '</script>\n' +
    '\n' +
    '<svelte:body\n' +
