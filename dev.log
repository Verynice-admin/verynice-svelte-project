    '\tdata-sveltekit-preload-data="hover"\n' +
    '/>\n' +
    '\n' +
    '<SiteHeader {headerConfig} bind:isSearchOpen on:search-open={() => isSearchOpen = true} />\n' +
    '\n' +
    '<main id="main-content" role="main">\n' +
    '\t<slot />\n' +
    '</main>\n' +
    '\n' +
    '<!-- Search Bar -->\n' +
    '<div class="global-search-bar">\n' +
